FROM --platform=linux/386 docker.io/i386/ubuntu:18.04

ARG DEBIAN_FRONTEND=noninteractive

RUN apt-get update && \
    apt-get -y upgrade && \
    apt-get install -y \
    apt-utils \
    ca-certificates \
    cowsay \
    cpio \
    cron \
    curl \
    g++ \
    gcc \
    git \
    hexedit \
    ifupdown \
    less \
    logrotate \
    lua5.3 \
    make \
    nano \
    netbase \
    nodejs \
    openssl \
    procps \
    python3 \
    python3-pip \
    python3-cryptography \
    python3-jinja2 \
    python3-numpy \
    python3-pandas \
    python3-scipy \
    python3-six \
    python3-yaml \
    ruby \
    vim \
    wget \
    whiptail \
    xxd \
    iptables \
    kmod \
    netcat-openbsd \
    openssh-server \
    lshw \
    lynx

RUN useradd -m user && echo "user:password" | chpasswd

COPY --chown=user:user ./examples /home/user/examples
RUN chmod -R +x /home/user/examples/lua

WORKDIR /root

ENV HOME="/root" \
    TERM="xterm" \
    USER="root" \
    SHELL="/bin/bash" \
    EDITOR="vim" \
    LANG="C.UTF-8"

RUN echo 'root:password' | chpasswd

CMD ["/bin/bash"]
