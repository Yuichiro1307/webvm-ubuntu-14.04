FROM --platform=linux/386 docker.io/i386/ubuntu:18.04

ARG DEBIAN_FRONTEND=noninteractive

RUN apt-get update && \
    apt-get install -y \
    bash \
    coreutils \
    util-linux \
    vim \
    curl \
    netcat \
    python3 \
    gcc \
    git \
    make

RUN useradd -m user && echo "user:password" | chpasswd

COPY --chown=user:user ./examples /home/user/examples
RUN chmod -R +x /home/user/examples/lua

WORKDIR /home/user/

ENV HOME="/home/user" \
    TERM="xterm" \
    USER="user" \
    SHELL="/bin/bash" \
    EDITOR="vim" \
    LANG="C.UTF-8"

RUN echo 'root:password' | chpasswd

CMD ["/bin/bash"]
